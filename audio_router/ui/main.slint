import { Button, CheckBox, ComboBox, ListView } from "std-widgets.slint";

export struct SourceDevice {
    id: string,
    name: string,
    selected: bool,
}

export struct DeviceRow {
    id: string,
    name: string,
    enabled: bool,
    channel-mode: int,
}

export struct SettingsState {
    start-with-windows: bool,
    minimized: bool,
    auto-route: bool,
    language-index: int,
}

component SectionTitle inherits Text {
    color: #9ca3af;
    font-size: 11px;
    font-weight: 700;
}

component DeviceName inherits Text {
    color: #f0f3f7;
    font-size: 14px;
    font-weight: 600;
    overflow: elide;
}

component DeviceId inherits Text {
    color: #6b7280;
    font-size: 11px;
    overflow: elide;
}

component SettingsRow inherits HorizontalLayout {
    in property <string> label;
    height: 36px;
    Text {
        text: root.label;
        color: #f0f3f7;
        font-size: 14px;
        vertical-alignment: center;
    }
}

export component MainWindow inherits Window {
    in property <string> status-text: "";
    in property <string> update-text: "";
    in property <int> device-count: 0;
    in property <bool> is-running: false;
    in-out property <bool> show-settings: false;
    in-out property <SettingsState> settings-state;
    in property <[SourceDevice]> source-devices;
    in property <[DeviceRow]> output-devices;
    in property <[string]> channel-mode-options;
    in property <string> i18n-status-running: "";
    in property <string> i18n-status-ready: "";
    in property <string> i18n-device-count-text: "";
    in property <string> i18n-settings: "";
    in property <string> i18n-settings-title: "";
    in property <string> i18n-source-device: "";
    in property <string> i18n-output-devices: "";
    in property <string> i18n-start: "";
    in property <string> i18n-stop: "";
    in property <string> i18n-start-with-windows: "";
    in property <string> i18n-start-minimized: "";
    in property <string> i18n-auto-route: "";
    in property <string> i18n-language: "";
    in property <string> i18n-cancel: "";
    in property <string> i18n-save: "";
    callback toggle-routing();
    callback select-source(string);
    callback set-output-enabled(string, bool);
    callback set-output-channel-mode(string, int);
    callback open-settings();
    callback save-settings(bool, bool, bool, int);
    callback cancel-settings();

    title: "AudioRouter";
    icon: @image-url("../assets/icon.png");
    preferred-width: 980px;
    preferred-height: 720px;
    min-width: 640px;
    min-height: 480px;
    background: #0b0f14;

    VerticalLayout {
        padding: 22px;
        spacing: 14px;

        HorizontalLayout {
            height: 42px;
            vertical-stretch: 0;
            spacing: 12px;
            Text {
                text: "AudioRouter";
                color: #f0f3f7;
                font-size: 22px;
                font-weight: 700;
                vertical-alignment: center;
            }

            Text {
                text: root.is-running ? root.i18n-status-running : root.i18n-status-ready;
                color: root.is-running ? #2bd97f : #9ca3af;
                font-size: 13px;
                vertical-alignment: center;
            }

            Rectangle {
                horizontal-stretch: 1;
            }

            Text {
                text: root.i18n-device-count-text;
                color: #6b7280;
                font-size: 12px;
                vertical-alignment: center;
            }

            Button {
                width: 82px;
                text: root.i18n-settings;
                clicked => {
                    root.open-settings();
                }
            }
        }

        HorizontalLayout {
            spacing: 16px;

            VerticalLayout {
                preferred-width: 260px;
                min-width: 200px;
                horizontal-stretch: 0;
                spacing: 10px;
                SectionTitle {
                    text: root.i18n-source-device;
                }

                Rectangle {
                    background: #111827;
                    border-color: #243041;
                    border-width: 1px;
                    border-radius: 8px;
                    clip: true;

                    ListView {
                        viewport-width: parent.width;
                        viewport-height: parent.height;
                        for source in root.source-devices: Rectangle {
                            height: 56px;
                            background: source.selected ? #1b2a36 : transparent;

                            Rectangle {
                                x: 12px;
                                y: (parent.height - self.height) / 2;
                                width: 4px;
                                height: 20px;
                                border-radius: 2px;
                                background: source.selected ? #2bd97f : transparent;
                            }

                            Text {
                                x: 26px;
                                y: (parent.height - self.height) / 2;
                                text: source.name;
                                color: source.selected ? #f0f3f7 : #cbd5e1;
                                font-size: 13px;
                                overflow: elide;
                            }

                            TouchArea {
                                clicked => {
                                    root.select-source(source.id);
                                }
                            }
                        }
                    }
                }
            }

            VerticalLayout {
                horizontal-stretch: 1;
                spacing: 10px;
                SectionTitle {
                    text: root.i18n-output-devices;
                }

                Rectangle {
                    background: #111827;
                    border-color: #243041;
                    border-width: 1px;
                    border-radius: 8px;
                    clip: true;

                    ListView {
                        viewport-width: parent.width;
                        viewport-height: parent.height;
                        for device in root.output-devices: Rectangle {
                            height: 74px;
                            background: device.enabled ? #111827 : #0f141d;

                            HorizontalLayout {
                                padding-left: 14px;
                                padding-right: 14px;
                                spacing: 12px;
                                alignment: center;

                                CheckBox {
                                    width: 34px;
                                    checked: device.enabled;
                                    toggled => {
                                        root.set-output-enabled(device.id, self.checked);
                                    }
                                }

                                VerticalLayout {
                                    spacing: 4px;
                                    DeviceName {
                                        text: device.name;
                                    }

                                    DeviceId {
                                        text: device.id;
                                    }
                                }

                                ComboBox {
                                    width: 160px;
                                    model: root.channel-mode-options;
                                    current-index: device.channel-mode;
                                    selected(value) => {
                                        root.set-output-channel-mode(device.id, self.current-index);
                                    }
                                }
                            }
                        }
                    }
                }
            }
        }

        Rectangle {
            height: 54px;
            vertical-stretch: 0;
            background: #0f1722;
            border-color: #243041;
            border-width: 1px;
            border-radius: 8px;

            HorizontalLayout {
                padding-left: 14px;
                padding-right: 14px;
                spacing: 12px;
                alignment: center;
                Text {
                    text: root.status-text;
                    color: #9ca3af;
                    font-size: 13px;
                    vertical-alignment: center;
                    overflow: elide;
                }

                Text {
                    text: root.update-text;
                    color: #2bd97f;
                    font-size: 12px;
                    vertical-alignment: center;
                    overflow: elide;
                }

                Rectangle {
                    horizontal-stretch: 1;
                }

                Button {
                    width: 96px;
                    text: root.is-running ? root.i18n-stop : root.i18n-start;
                    clicked => {
                        root.toggle-routing();
                    }
                }
            }
        }
    }

    if root.show-settings: Rectangle {
        width: 100%;
        height: 100%;
        background: #D9000000;
        TouchArea { }

        Rectangle {
            width: min(480px, max(320px, parent.width * 45%));
            height: min(400px, max(280px, parent.height * 55%));
            x: (parent.width - self.width) / 2;
            y: (parent.height - self.height) / 2;
            background: #1a2233;
            border-color: #2f3b4f;
            border-width: 1px;
            border-radius: 12px;
            clip: true;

            VerticalLayout {
                // 标题栏
                Rectangle {
                    height: 48px;
                    background: #111827;
                    HorizontalLayout {
                        padding-left: 18px;
                        Text {
                            text: root.i18n-settings-title;
                            color: #f0f3f7;
                            font-size: 16px;
                            font-weight: 700;
                            vertical-alignment: center;
                        }

                        Rectangle {
                            horizontal-stretch: 1;
                        }

                        Rectangle {
                            width: 28px;
                            height: 28px;
                            border-radius: 6px;
                            background: close-touch.has-hover ? #ef4444 : transparent;
                            close-touch := TouchArea {
                                clicked => {
                                    root.cancel-settings();
                                }
                            }

                            Text {
                                text: "X";
                                color: close-touch.has-hover ? #fff : #9ca3af;
                                font-size: 14px;
                                font-weight: 700;
                                horizontal-alignment: center;
                                vertical-alignment: center;
                            }
                        }
                    }
                }

                Rectangle {
                    height: 1px;
                    background: #243041;
                }

                // 内容区
                VerticalLayout {
                    padding: 18px;
                    spacing: 12px;

                    SettingsRow {
                        label: root.i18n-start-with-windows;
                        CheckBox {
                            checked: root.settings-state.start-with-windows;
                            toggled => {
                                root.settings-state.start-with-windows = self.checked;
                            }
                        }
                    }

                    SettingsRow {
                        label: root.i18n-start-minimized;
                        CheckBox {
                            checked: root.settings-state.minimized;
                            toggled => {
                                root.settings-state.minimized = self.checked;
                            }
                        }
                    }

                    SettingsRow {
                        label: root.i18n-auto-route;
                        CheckBox {
                            checked: root.settings-state.auto-route;
                            toggled => {
                                root.settings-state.auto-route = self.checked;
                            }
                        }
                    }

                    HorizontalLayout {
                        height: 36px;
                        Text {
                            text: root.i18n-language;
                            color: #f0f3f7;
                            font-size: 14px;
                            vertical-alignment: center;
                        }

                        Rectangle {
                            horizontal-stretch: 1;
                        }

                        ComboBox {
                            width: 140px;
                            model: ["English", "简体中文"];
                            current-index: root.settings-state.language-index;
                            selected(value) => {
                                root.settings-state.language-index = value == "简体中文" ? 1 : 0;
                            }
                        }
                    }
                }

                Rectangle {
                    vertical-stretch: 1;
                }

                // 底部按钮栏
                Rectangle {
                    height: 1px;
                    background: #243041;
                }

                HorizontalLayout {
                    height: 52px;
                    padding: 12px;
                    spacing: 10px;
                    alignment: end;
                    Button {
                        text: root.i18n-cancel;
                        clicked => {
                            root.cancel-settings();
                        }
                    }

                    Button {
                        text: root.i18n-save;
                        clicked => {
                            root.save-settings(
                                root.settings-state.start-with-windows,
                                root.settings-state.minimized,
                                root.settings-state.auto-route,
                                root.settings-state.language-index,
                            );
                        }
                    }
                }
            }
        }
    }
}
