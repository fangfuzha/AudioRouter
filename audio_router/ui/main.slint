import { Button, CheckBox, ListView } from "std-widgets.slint";

export struct SourceDevice {
    id: string,
    name: string,
    selected: bool,
}

export struct DeviceRow {
    id: string,
    name: string,
    enabled: bool,
    channel-mode: int,
    channel-label: string,
}

component SectionTitle inherits Text {
    color: #9ca3af;
    font-size: 11px;
    font-weight: 700;
}

component DeviceName inherits Text {
    color: #f0f3f7;
    font-size: 14px;
    font-weight: 600;
    overflow: elide;
}

component DeviceId inherits Text {
    color: #6b7280;
    font-size: 11px;
    overflow: elide;
}

export component MainWindow inherits Window {
    in property <string> status-text: "";
    in property <int> device-count: 0;
    in property <bool> is-running: false;
    in property <[SourceDevice]> source-devices;
    in property <[DeviceRow]> output-devices;
    callback refresh-devices();
    callback toggle-routing();
    callback select-source(string);
    callback set-output-enabled(string, bool);
    callback next-channel-mode(string);

    title: "AudioRouter";
    width: 900px;
    height: 720px;
    background: #0b0f14;

    VerticalLayout {
        padding: 22px;
        spacing: 16px;

        HorizontalLayout {
            height: 42px;
            Text {
                text: "AudioRouter";
                color: #f0f3f7;
                font-size: 22px;
                font-weight: 700;
                vertical-alignment: center;
            }
            Rectangle { width: 1px; }
            Text {
                text: root.is-running ? "运行中" : "就绪";
                color: root.is-running ? #2bd97f : #9ca3af;
                font-size: 13px;
                vertical-alignment: center;
            }
            Button {
                text: "刷新设备";
                clicked => { root.refresh-devices(); }
            }
        }

        GridLayout {
            spacing: 16px;
            Row {
                VerticalLayout {
                    spacing: 10px;
                    SectionTitle { text: "源设备"; }
                    Rectangle {
                        height: 150px;
                        background: #111827;
                        border-color: #243041;
                        border-width: 1px;
                        border-radius: 8px;
                        ListView {
                            viewport-width: parent.width;
                            viewport-height: parent.height;
                            for source in root.source-devices: Rectangle {
                                height: 42px;
                                background: source.selected ? #1b2a36 : transparent;
                                border-radius: 6px;
                                TouchArea {
                                    clicked => { root.select-source(source.id); }
                                }
                                HorizontalLayout {
                                    padding-left: 12px;
                                    padding-right: 12px;
                                    Text {
                                        text: source.name;
                                        color: source.selected ? #2bd97f : #f0f3f7;
                                        font-size: 13px;
                                        vertical-alignment: center;
                                        overflow: elide;
                                    }
                                }
                            }
                        }
                    }
                }
            }
        }

        VerticalLayout {
            spacing: 10px;
            SectionTitle { text: "输出设备"; }
            Rectangle {
                background: #111827;
                border-color: #243041;
                border-width: 1px;
                border-radius: 8px;

                ListView {
                    viewport-width: parent.width;
                    viewport-height: parent.height;
                    for device in root.output-devices: Rectangle {
                        height: 66px;
                        background: device.enabled ? #111827 : #0f141d;
                        border-radius: 6px;

                        HorizontalLayout {
                            padding-left: 14px;
                            padding-right: 14px;
                            spacing: 12px;

                            CheckBox {
                                checked: device.enabled;
                                toggled => { root.set-output-enabled(device.id, self.checked); }
                            }

                            VerticalLayout {
                                spacing: 3px;
                                DeviceName { text: device.name; }
                                DeviceId { text: device.id; }
                            }

                            Button {
                                width: 128px;
                                text: device.channel-label;
                                clicked => { root.next-channel-mode(device.id); }
                            }
                        }
                    }
                }
            }
        }

        Rectangle {
            height: 54px;
            background: #0f1722;
            border-color: #243041;
            border-width: 1px;
            border-radius: 8px;

            HorizontalLayout {
                padding-left: 14px;
                padding-right: 14px;
                spacing: 12px;
                Text {
                    text: root.status-text;
                    color: #9ca3af;
                    font-size: 13px;
                    vertical-alignment: center;
                    overflow: elide;
                }
                Text {
                    text: "设备：" + root.device-count;
                    color: #6b7280;
                    font-size: 12px;
                    vertical-alignment: center;
                }
                Button {
                    text: root.is-running ? "停止" : "启动";
                    clicked => { root.toggle-routing(); }
                }
            }
        }
    }
}
