import { Button, CheckBox, ComboBox, ListView } from "std-widgets.slint";

export struct SourceDevice {
    id: string,
    name: string,
    selected: bool,
}

export struct DeviceRow {
    id: string,
    name: string,
    enabled: bool,
    channel-mode: int,
    channel-label: string,
}

export struct SettingsState {
    start-with-windows: bool,
    minimized: bool,
    auto-route: bool,
    language-index: int,
}

component SectionTitle inherits Text {
    color: #9ca3af;
    font-size: 11px;
    font-weight: 700;
}

component DeviceName inherits Text {
    color: #f0f3f7;
    font-size: 14px;
    font-weight: 600;
    overflow: elide;
}

component DeviceId inherits Text {
    color: #6b7280;
    font-size: 11px;
    overflow: elide;
}

component SettingsRow inherits HorizontalLayout {
    in property <string> label;
    height: 36px;
    Text {
        text: root.label;
        color: #f0f3f7;
        font-size: 14px;
        vertical-alignment: center;
    }
}

export component MainWindow inherits Window {
    in property <string> status-text: "";
    in property <string> update-text: "";
    in property <int> device-count: 0;
    in property <bool> is-running: false;
    in-out property <bool> show-settings: false;
    in-out property <SettingsState> settings-state;
    in property <[SourceDevice]> source-devices;
    in property <[DeviceRow]> output-devices;
    callback refresh-devices();
    callback toggle-routing();
    callback select-source(string);
    callback set-output-enabled(string, bool);
    callback next-channel-mode(string);
    callback open-settings();
    callback save-settings(bool, bool, bool, int);
    callback cancel-settings();

    title: "AudioRouter";
    icon: @image-url("../assets/icon.png");
    width: 900px;
    height: 720px;
    background: #0b0f14;

    VerticalLayout {
        padding: 22px;
        spacing: 16px;

        HorizontalLayout {
            height: 42px;
            Text {
                text: "AudioRouter";
                color: #f0f3f7;
                font-size: 22px;
                font-weight: 700;
                vertical-alignment: center;
            }
            Rectangle { width: 1px; }
            Text {
                text: root.is-running ? "运行中" : "就绪";
                color: root.is-running ? #2bd97f : #9ca3af;
                font-size: 13px;
                vertical-alignment: center;
            }
            Button {
                text: "设置";
                clicked => { root.open-settings(); }
            }
            Button {
                text: "刷新设备";
                clicked => { root.refresh-devices(); }
            }
        }

        GridLayout {
            spacing: 16px;
            Row {
                VerticalLayout {
                    spacing: 10px;
                    SectionTitle { text: "源设备"; }
                    Rectangle {
                        height: 150px;
                        background: #111827;
                        border-color: #243041;
                        border-width: 1px;
                        border-radius: 8px;
                        ListView {
                            viewport-width: parent.width;
                            viewport-height: parent.height;
                            for source in root.source-devices: Rectangle {
                                height: 42px;
                                background: source.selected ? #1b2a36 : transparent;
                                border-radius: 6px;
                                TouchArea {
                                    clicked => { root.select-source(source.id); }
                                }
                                HorizontalLayout {
                                    padding-left: 12px;
                                    padding-right: 12px;
                                    Text {
                                        text: source.name;
                                        color: source.selected ? #2bd97f : #f0f3f7;
                                        font-size: 13px;
                                        vertical-alignment: center;
                                        overflow: elide;
                                    }
                                }
                            }
                        }
                    }
                }
            }
        }

        VerticalLayout {
            spacing: 10px;
            SectionTitle { text: "输出设备"; }
            Rectangle {
                background: #111827;
                border-color: #243041;
                border-width: 1px;
                border-radius: 8px;

                ListView {
                    viewport-width: parent.width;
                    viewport-height: parent.height;
                    for device in root.output-devices: Rectangle {
                        height: 66px;
                        background: device.enabled ? #111827 : #0f141d;
                        border-radius: 6px;

                        HorizontalLayout {
                            padding-left: 14px;
                            padding-right: 14px;
                            spacing: 12px;

                            CheckBox {
                                checked: device.enabled;
                                toggled => { root.set-output-enabled(device.id, self.checked); }
                            }

                            VerticalLayout {
                                spacing: 3px;
                                DeviceName { text: device.name; }
                                DeviceId { text: device.id; }
                            }

                            Button {
                                width: 128px;
                                text: device.channel-label;
                                clicked => { root.next-channel-mode(device.id); }
                            }
                        }
                    }
                }
            }
        }

        Rectangle {
            height: 54px;
            background: #0f1722;
            border-color: #243041;
            border-width: 1px;
            border-radius: 8px;

            HorizontalLayout {
                padding-left: 14px;
                padding-right: 14px;
                spacing: 12px;
                Text {
                    text: root.status-text;
                    color: #9ca3af;
                    font-size: 13px;
                    vertical-alignment: center;
                    overflow: elide;
                }
                Text {
                    text: root.update-text;
                    color: #2bd97f;
                    font-size: 12px;
                    vertical-alignment: center;
                    overflow: elide;
                }
                Text {
                    text: "设备：" + root.device-count;
                    color: #6b7280;
                    font-size: 12px;
                    vertical-alignment: center;
                }
                Button {
                    text: root.is-running ? "停止" : "启动";
                    clicked => { root.toggle-routing(); }
                }
            }
        }
    }

    if root.show-settings: Rectangle {
        background: #99000000;
        TouchArea {}

        Rectangle {
            width: 360px;
            height: 318px;
            x: (parent.width - self.width) / 2;
            y: (parent.height - self.height) / 2;
            background: #111827;
            border-color: #2f3b4f;
            border-width: 1px;
            border-radius: 8px;

            VerticalLayout {
                padding: 22px;
                spacing: 14px;

                Text {
                    text: "设置";
                    color: #f0f3f7;
                    font-size: 18px;
                    font-weight: 700;
                }

                SettingsRow {
                    label: "开机自启";
                    CheckBox { checked: root.settings-state.start-with-windows; toggled => { root.settings-state.start-with-windows = self.checked; } }
                }

                SettingsRow {
                    label: "启动时最小化";
                    CheckBox { checked: root.settings-state.minimized; toggled => { root.settings-state.minimized = self.checked; } }
                }

                SettingsRow {
                    label: "启动时自动路由";
                    CheckBox { checked: root.settings-state.auto-route; toggled => { root.settings-state.auto-route = self.checked; } }
                }

                HorizontalLayout {
                    height: 38px;
                    Text {
                        text: "语言";
                        color: #f0f3f7;
                        font-size: 14px;
                        vertical-alignment: center;
                    }
                    ComboBox {
                        width: 150px;
                        model: ["English", "简体中文"];
                        current-index: root.settings-state.language-index;
                        selected(value) => { root.settings-state.language-index = value == "简体中文" ? 1 : 0; }
                    }
                }

                Rectangle { height: 1px; background: #243041; }

                HorizontalLayout {
                    spacing: 10px;
                    Rectangle { width: 1px; }
                    Button {
                        text: "取消";
                        clicked => { root.cancel-settings(); }
                    }
                    Button {
                        text: "保存设置";
                        clicked => {
                            root.save-settings(
                                root.settings-state.start-with-windows,
                                root.settings-state.minimized,
                                root.settings-state.auto-route,
                                root.settings-state.language-index,
                            );
                        }
                    }
                }
            }
        }
    }
}


