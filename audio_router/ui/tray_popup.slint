component PopupAction inherits Rectangle {
    in property <string> text;
    in property <bool> danger: false;
    callback clicked();

    height: 32px;
    border-radius: 4px;
    background: action-touch.has-hover ? #2d3140 : transparent;
    animate background { duration: 100ms; easing: ease-out; }

    Rectangle {
        x: 0;
        y: 4px;
        width: 3px;
        height: parent.height - 8px;
        border-radius: 1.5px;
        background: #2bd97f;
        opacity: action-touch.has-hover ? 1.0 : 0.0;
        animate opacity { duration: 100ms; easing: ease-out; }
    }

    Text {
        x: 14px;
        width: parent.width - 24px;
        height: parent.height;
        text: root.text;
        color: root.danger ? #ef4444 : (action-touch.has-hover ? #e4e6ea : #8b8f98);
        font-size: 12px;
        font-weight: 400;
        vertical-alignment: center;
        overflow: elide;
        animate color { duration: 100ms; easing: ease-out; }
    }

    action-touch := TouchArea {
        mouse-cursor: pointer;
        clicked => {
            root.clicked();
        }
    }
}

export component TrayPopupWindow inherits Window {
    in property <bool> routing-running;
    callback show-main-window();
    callback toggle-routing();
    callback quit-app();
    callback request-close();

    title: "AudioRouter";
    no-frame: true;
    always-on-top: true;
    preferred-width: 180px;
    preferred-height: 160px;
    min-width: 180px;
    min-height: 160px;
    max-width: 180px;
    max-height: 160px;
    background: transparent;

    FocusScope {
        key-pressed(event) => {
            if (event.text == Key.Escape) {
                root.request-close();
                return accept;
            }
            return reject;
        }
    }

    Rectangle {
        background: #1e1e2e;
        border-color: #2a2d38;
        border-width: 1px;
        border-radius: 8px;
        drop-shadow-color: #00000040;
        drop-shadow-blur: 16px;
        drop-shadow-offset-y: 4px;

        VerticalLayout {
            padding: 6px;
            spacing: 0px;

            // 标题区
            Rectangle {
                height: 28px;

                HorizontalLayout {
                    padding-left: 4px;
                    padding-right: 4px;
                    spacing: 0px;
                    alignment: start;

                    Text {
                        text: "AudioRouter";
                        color: #e4e6ea;
                        font-size: 12px;
                        font-weight: 600;
                        vertical-alignment: center;
                    }
                    Rectangle { width: 4px; }
                    Rectangle {
                        width: 6px;
                        height: 6px;
                        y: (parent.height - self.height) / 2;
                        border-radius: 3px;
                        background: root.routing-running ? #2bd97f : #4a4e5a;
                    }
                }
            }

            // 分割线
            Rectangle {
                height: 1px;
                background: #2a2d38;
            }

            // 菜单项
            PopupAction {
                text: "打开主窗口";
                clicked => {
                    root.show-main-window();
                }
            }

            PopupAction {
                text: root.routing-running ? "停止路由" : "启动路由";
                clicked => {
                    root.toggle-routing();
                }
            }

            // 分割线
            Rectangle {
                height: 1px;
                background: #2a2d38;
            }

            PopupAction {
                text: "退出应用";
                danger: true;
                clicked => {
                    root.quit-app();
                }
            }
        }
    }
}
